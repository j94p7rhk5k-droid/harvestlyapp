# ── Client-side Firebase (public — embedded in the bundle) ────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Anthropic (server-only) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Firebase Admin (server-only) ──────────────────────────────────────────
# Paste the entire service-account JSON on a single line. Generate one in
# Firebase console → Project settings → Service accounts → Generate new
# private key. Required for /api/chat and /api/import to verify ID tokens.
FIREBASE_SERVICE_ACCOUNT_JSON=
